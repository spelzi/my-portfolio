# Copy this file to .env and fill in real values:
#   cp .env.example .env
#
# Never commit your actual .env file — it's already covered by .gitignore.

# Base URL of the backend API (Node/Express, deployed separately on Railway).
# Used for: the contact form (/send-email) and admin auth (/api/auth/login).
# Local development example: http://localhost:3001
VITE_BACKEND_URL=http://localhost:3001

# Public URL of THIS frontend (used for canonical links, OG image URLs,
# and sitemap.xml generation at build time).
# Replace with your actual deployed domain once you have one.
VITE_SITE_URL=https://your-domain.com
